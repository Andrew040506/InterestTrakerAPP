<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:InterestTrakerAPP.ViewModels"
             xmlns:models="clr-namespace:InterestTrakerAPP.Models"
             x:Class="InterestTrakerAPP.Views.PortfolioPage"
             x:DataType="viewmodels:PortfolioViewModel"
             BackgroundColor="#fcf8fa"
             Title="Portfolio">

    <Grid RowDefinitions="Auto, Auto, *" Padding="20">

        <Border Grid.Row="0" Stroke="#e4e2e4" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="#ffffff" Margin="0,0,0,24" Padding="24">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.05" />
            </Border.Shadow>

            <VerticalStackLayout>
                <Label Text="TOTAL PORTFOLIO VALUE" FontSize="12" TextColor="#76777d" FontAttributes="Bold" Margin="0,0,0,4"/>
                <Label Text="{Binding DisplayTotalValue}" FontSize="36" FontAttributes="Bold" TextColor="#000000" Margin="0,0,0,16"/>

                <BoxView HeightRequest="1" Color="#e4e2e4" Margin="0,0,0,16"/>

                <VerticalStackLayout>
                    <Label Text="Unrealized PnL" FontSize="12" TextColor="#76777d"/>
                    <Label Text="{Binding DisplayUnrealizedPnL}" FontSize="18" FontAttributes="Bold">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsOverallProfitable}" Value="True">
                                <Setter Property="TextColor" Value="#006c49" />
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsOverallProfitable}" Value="False">
                                <Setter Property="TextColor" Value="#ba1a1a" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*, Auto" Margin="0,0,0,16">
            <Label Grid.Column="0" Text="Holdings" FontSize="20" FontAttributes="Bold" TextColor="#000000" VerticalOptions="Center"/>
            <Button Grid.Column="1" 
                    Text="+ Add" 
                    Clicked="OnAddClicked"
                    BackgroundColor="#006c49" 
                    TextColor="White"
                    FontAttributes="Bold"
                    Padding="16,0"
                    CornerRadius="8"
                    HeightRequest="36"
                    VerticalOptions="Center"/>
        </Grid>

        <RefreshView Grid.Row="2" IsRefreshing="{Binding IsRefreshing}" Command="{Binding LoadPortfolioDataCommand}">
            <CollectionView ItemsSource="{Binding Holdings}" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:PortfolioItem">

                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItems>
                                    <SwipeItem Text="Delete" 
                                               BackgroundColor="#ba1a1a" 
                                               Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:PortfolioViewModel}}, Path=DeleteHoldingCommand}" 
                                               CommandParameter="{Binding .}"/>
                                </SwipeItems>
                            </SwipeView.RightItems>

                            <Border Stroke="#e4e2e4" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="#ffffff" Margin="0,0,0,12" Padding="16">

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer 
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:PortfolioViewModel}}, Path=NavigateToTradeCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>

                                <Grid ColumnDefinitions="Auto, *, Auto">

                                    <Border Grid.Column="0" WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 20" BackgroundColor="#131b2e" Margin="0,0,12,0" VerticalOptions="Center">
                                        <Label Text="{Binding IconLetter}" HorizontalOptions="Center" VerticalOptions="Center" TextColor="White" FontSize="16" FontAttributes="Bold"/>
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                        <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" TextColor="#000000"/>
                                        <HorizontalStackLayout Spacing="6">
                                            <Border BackgroundColor="#f6f3f5" Stroke="Transparent" StrokeShape="RoundRectangle 4" Padding="4,2">
                                                <Label Text="{Binding Symbol}" FontSize="10" TextColor="#45464d" FontAttributes="Bold"/>
                                            </Border>
                                            <Label Text="{Binding AssetClass}" FontSize="12" TextColor="#76777d" VerticalOptions="Center"/>
                                        </HorizontalStackLayout>
                                        <Label Text="{Binding DisplayHoldings}" FontSize="12" TextColor="#45464d" Margin="0,4,0,0"/>
                                        <Label Text="{Binding DisplayTotalValue}" FontSize="14" FontAttributes="Bold" TextColor="#000000"/>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" HorizontalOptions="End" Spacing="2">
                                        <Label Text="Live Price" FontSize="10" TextColor="#76777d" HorizontalOptions="End"/>
                                        <Label Text="{Binding DisplayLivePrice}" FontSize="16" FontAttributes="Bold" TextColor="#000000" HorizontalOptions="End"/>
                                        <Label Text="PnL / Avg Cost" FontSize="10" TextColor="#76777d" HorizontalOptions="End" Margin="0,8,0,0"/>
                                        <Border BackgroundColor="#e6fbd4" Stroke="Transparent" StrokeShape="RoundRectangle 4" Padding="6,2" HorizontalOptions="End">
                                            <Label Text="{Binding DisplayPnL}" FontSize="12" TextColor="#006c49" FontAttributes="Bold"/>
                                        </Border>
                                        <Label Text="{Binding AvgCostDisplay}" FontSize="12" TextColor="#76777d" HorizontalOptions="End"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>