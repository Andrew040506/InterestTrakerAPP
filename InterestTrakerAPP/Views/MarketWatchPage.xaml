<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:InterestTrakerAPP.ViewModels"
             xmlns:models="clr-namespace:InterestTrakerAPP.Models" 
             x:Class="InterestTrakerAPP.Views.MarketWatchPage"
             x:DataType="viewmodels:MarketWatchViewModel"
             BackgroundColor="#fcf8fa"
             Title="Market Explorer">

    <Grid RowDefinitions="Auto, Auto, *" Padding="20">

        <VerticalStackLayout Grid.Row="0" Spacing="16" Margin="0,0,0,16">
            <Label Text="WealthShield" 
                   FontAttributes="Bold" 
                   FontSize="24" 
                   TextColor="#000000" />

            <Border Stroke="#c6c6cd" 
                    StrokeThickness="1" 
                    StrokeShape="RoundRectangle 12"
                    BackgroundColor="#f6f3f5"
                    Padding="4">
                <Grid ColumnDefinitions="*, Auto">
                    <SearchBar x:Name="AssetSearchBar"
                               Grid.Column="0" 
                               Text="{Binding SearchSymbolText}"
                               Placeholder="Search assets (e.g. TSLA, BINANCE:ETHUSDT)..."
                               BackgroundColor="Transparent"
                               CancelButtonColor="#76777d"
                               TextColor="#000000"
                               PlaceholderColor="#76777d"/>

                    <Button Grid.Column="1"
                            Text="Add"
                            Command="{Binding AddSymbolCommand}"
                            BackgroundColor="#006c49"
                            TextColor="White"
                            CornerRadius="8"
                            Margin="0,4,4,4"
                            Padding="12,0"
                            FontAttributes="Bold"/>
                </Grid>
            </Border>

            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout Spacing="12">
                    <Border BackgroundColor="#131b2e" StrokeShape="RoundRectangle 6" Padding="16,8">
                        <Label Text="All Assets" TextColor="White" FontSize="12" FontAttributes="Bold"/>
                    </Border>
                    <Border BackgroundColor="#ffffff" Stroke="#c6c6cd" StrokeShape="RoundRectangle 6" Padding="16,8">
                        <Label Text="Crypto" TextColor="#45464d" FontSize="12" FontAttributes="Bold"/>
                    </Border>
                    <Border BackgroundColor="#ffffff" Stroke="#c6c6cd" StrokeShape="RoundRectangle 6" Padding="16,8">
                        <Label Text="Stocks" TextColor="#45464d" FontSize="12" FontAttributes="Bold"/>
                    </Border>
                </HorizontalStackLayout>
            </ScrollView>
        </VerticalStackLayout>

        <Grid Grid.Row="1" ColumnDefinitions="*, Auto" Margin="0,16,0,12">
            <Label Grid.Column="0" Text="Your Watchlist" FontSize="20" FontAttributes="Bold" TextColor="#000000" VerticalOptions="End"/>
            <Label Grid.Column="1" Text="Live Data via Finnhub" FontSize="12" TextColor="#006c49" VerticalOptions="End"/>
        </Grid>

        <RefreshView Grid.Row="2" 
                     IsRefreshing="{Binding IsRefreshing}" 
                     Command="{Binding LoadPricesCommand}">

            <CollectionView ItemsSource="{Binding Watchlist}" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:AssetQuote">
                        <Border Stroke="#e4e2e4" 
                                StrokeThickness="1" 
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="#ffffff"
                                Margin="0,0,0,12"
                                Padding="16">

                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.04" />
                            </Border.Shadow>

                            <Grid ColumnDefinitions="Auto, *, Auto">

                                <Border Grid.Column="0" 
                                        WidthRequest="40" HeightRequest="40" 
                                        StrokeShape="RoundRectangle 20" 
                                        BackgroundColor="#eae7e9"
                                        Stroke="Transparent"
                                        Margin="0,0,12,0"
                                        VerticalOptions="Center">
                                    <Label Text="{Binding Symbol}" 
                                           HorizontalOptions="Center" 
                                           VerticalOptions="Center"
                                           TextColor="#131b2e"
                                           FontSize="10"
                                           FontAttributes="Bold"/>
                                </Border>

                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding Symbol}" 
                                           FontSize="16" 
                                           FontAttributes="Bold" 
                                           TextColor="#000000"/>
                                    <Label Text="Tracking" 
                                           FontSize="12" 
                                           TextColor="#45464d"/>
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" HorizontalOptions="End" Spacing="2">
                                    <Label Text="{Binding DisplayPrice}" 
                                           FontSize="16" 
                                           FontAttributes="Bold" 
                                           TextColor="#000000"
                                           HorizontalOptions="End"/>
                                    <Border BackgroundColor="#e6fbd4" Stroke="Transparent" StrokeShape="RoundRectangle 4" Padding="6,2" HorizontalOptions="End">
                                        <Label Text="LIVE" FontSize="10" TextColor="#006c49" FontAttributes="Bold"/>
                                    </Border>
                                </VerticalStackLayout>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>