<?xml version="1.0" encoding="utf-8" ?>
<Shell
    x:Class="InterestTrakerAPP.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:InterestTrakerAPP.Views"
    Shell.FlyoutBehavior="Disabled">

    <!-- The TabBar creates the native bottom navigation -->
    <TabBar>

        <!-- Explorer Tab -->
        <Tab Title="Explorer">
            <ShellContent ContentTemplate="{DataTemplate views:MarketWatchPage}" Route="MarketWatchPage" />
        </Tab>

        <!-- Portfolio Tab -->
        <Tab Title="Portfolio">
            <ShellContent ContentTemplate="{DataTemplate views:PortfolioPage}" Route="PortfolioPage" />
        </Tab>

        <!-- Note: We will add the Ledger, Goals, and Tools tabs here as we create those files! -->

    </TabBar>

</Shell>