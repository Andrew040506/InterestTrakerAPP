<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="InterestTrakerAPP.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:InterestTrakerAPP.Views"
    Shell.FlyoutBehavior="Disabled">

    <TabBar>
        <Tab Title="Explorer">
            <ShellContent ContentTemplate="{DataTemplate views:MarketWatchPage}" Route="MarketWatchPage" />
        </Tab>

        <Tab Title="Portfolio">
            <ShellContent ContentTemplate="{DataTemplate views:PortfolioPage}" Route="PortfolioPage" />
        </Tab>

        <Tab Title="Ledger">
            <ShellContent ContentTemplate="{DataTemplate views:LedgerPage}" Route="LedgerPage" />
        </Tab>
    </TabBar>

</Shell>